# This file is for documentation purposes only.
# In Coolify, add these environment variables in the Project Settings -> Environment Variables.

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Add your secrets here
# DATABASE_URL=...
# STRIPE_SECRET_KEY=...

# CMS database (Postgres) — required for form submissions and the /admin panel.
# Provision a Postgres instance (e.g. one-click on Coolify) and set the URL.
DATABASE_URL=postgres://user:password@host:5432/spares
# Optional Docker Compose database settings. Coolify generates
# SERVICE_PASSWORD_POSTGRES automatically for the bundled database.
POSTGRES_USER=spares
POSTGRES_DB=spares
SERVICE_PASSWORD_POSTGRES=
# Set only when using a separate managed PostgreSQL service.
APP_DATABASE_URL=

# Initial admin account, seeded automatically on first boot when no staff exist.
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# Transactional email for sales-desk form notifications.
# Option A (recommended): Resend API key.
RESEND_API_KEY=
# Option B (fallback): SMTP via nodemailer.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# Sender + recipient for notifications (defaults to the trade desk).
MAIL_FROM=Spares Automation <trade@spares-automation.co.uk>
SALES_DESK_EMAIL=trade@spares-automation.co.uk

# Local persistent storage for part-inquiry photo uploads.
# Mount a volume here in production (see docker-compose.yml).
UPLOAD_DIR=./data/uploads

# Shopify Storefront API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_PRIVATE_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_API_VERSION=2026-01

# Shopify Admin API (required for website quote submissions)
# Create a custom app with the write_draft_orders access scope.
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_ADMIN_API_VERSION=2026-01

# Shopify Customer Account API
# Get these from Shopify Admin -> Sales channels -> Headless -> Storefront -> Customer Account API.
# Shopify requires HTTPS callback URLs, so use your deployed domain or an HTTPS tunnel for local testing.

# App-owned secret used to encrypt the customer login session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SESSION_SECRET=
